# Firebase Configuration
# Copy this file to .env.local and fill in your Firebase project values

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_USE_FUNCTIONS_EMULATOR=false

# Google Identity Services OAuth 2.0 web client ID. Configure authorized
# JavaScript origins in Google Cloud Console before enabling Drive or Gmail.
VITE_GOOGLE_OAUTH_CLIENT_ID=your_web_oauth_client_id.apps.googleusercontent.com

# Stripe (publishable key only - secret key goes in Cloud Functions)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
