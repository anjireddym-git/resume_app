rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Users collection - users can read their own data, but credits can only be modified by Cloud Functions (admin SDK)
    match /users/{userId} {
      // Allow read for own document
      allow read: if isAuthenticated() && isOwner(userId);
      
      // Allow create/update but protect credits field from client writes
      allow create: if isAuthenticated() && isOwner(userId) && 
        !('credits' in request.resource.data);
      allow update: if isAuthenticated() && isOwner(userId) && 
        (!('credits' in request.resource.data) || request.resource.data.credits == resource.data.credits);
      
      // Transactions subcollection - read only for users, Cloud Functions write
      match /transactions/{transactionId} {
        allow read: if isAuthenticated() && isOwner(userId);
        // Writes only via Cloud Functions (admin SDK bypasses rules)
      }

      // Outreach email templates - full CRUD for the owner
      match /emailTemplates/{templateId} {
        allow read, create, update, delete: if isAuthenticated() && isOwner(userId);
      }

      // App-created Google Docs are deleted when the user next authorizes Drive.
      match /driveCleanup/{fileId} {
        allow read, create, update, delete: if isAuthenticated() && isOwner(userId);
      }
    }
    
    // Resume Groups collection - users can only access their own groups
    match /resumeGroups/{groupId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // Resumes collection - users can only access their own resumes
    match /resumes/{resumeId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // Versions subcollection - accessible if parent resume belongs to user
      match /versions/{versionId} {
        allow read, write: if isAuthenticated() && 
          get(/databases/$(database)/documents/resumes/$(resumeId)).data.userId == request.auth.uid;
      }
    }

    // Sent recruiter applications (Tailor-and-Send flow). Users own their docs.
    match /sentApplications/{appId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;

      // Reply subdocs are written by Cloud Functions (admin SDK bypasses rules)
      // but the user must be able to read them and mark them seen.
      match /replies/{replyId} {
        allow read: if isAuthenticated() &&
          get(/databases/$(database)/documents/sentApplications/$(appId)).data.userId == request.auth.uid;
        allow update: if isAuthenticated() &&
          get(/databases/$(database)/documents/sentApplications/$(appId)).data.userId == request.auth.uid;
      }

      // Outgoing follow-ups are saved after Gmail confirms the send so the
      // Sent view can render the complete conversation thread.
      match /outgoingMessages/{messageId} {
        allow read: if isAuthenticated() &&
          get(/databases/$(database)/documents/sentApplications/$(appId)).data.userId == request.auth.uid;
        allow create, update: if isAuthenticated() &&
          get(/databases/$(database)/documents/sentApplications/$(appId)).data.userId == request.auth.uid &&
          request.resource.data.userId == request.auth.uid;
      }
    }

    // Durable pre-send outreach workflows. Cloud Functions own status changes,
    // credits, generated resume linkage, and sent linkage. Clients may edit
    // only draft/review fields for their own flow.
    match /outreachFlows/{flowId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Created by Cloud Functions so clients cannot forge server-owned status
      // or credit fields.
      allow create: if false;
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == resource.data.userId &&
        (
          (
            resource.data.status == 'draft' &&
            request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'jobDescription',
              'sourceResumeId',
              'updatedAt',
            ])
          ) ||
          (
            resource.data.status == 'ready_to_send' &&
            request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'emailDraft',
              'followUp',
              'updatedAt',
            ])
          ) ||
          (
            !(resource.data.status in ['queued', 'tailoring', 'drafting_email']) &&
            request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'archived',
              'updatedAt',
            ])
          )
        );

      match /events/{eventId} {
        allow read: if isAuthenticated() &&
          get(/databases/$(database)/documents/outreachFlows/$(flowId)).data.userId == request.auth.uid;
      }
    }

    // Follow-up / reply notifications (created by scheduled Cloud Function).
    match /notifications/{notifId} {
      allow read, update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // create/delete only via Cloud Functions (admin SDK)
    }

    // Collection-group rule: lets the live Outreach badge query all
    // `replies` subdocs filtered by userId server-side. Per-doc reads
    // already allowed via the nested rule under sentApplications.
    match /{path=**}/replies/{replyId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Address -> uid index used by Gmail Pub/Sub push handler. Read-only to clients.
    match /gmailAddressIndex/{email} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
